class Personagem {

    // Atributos privados
    private String nome;
    private int vida;
    private int ataque;

    // Construtor com validação
    public Personagem(String nome, int vida, int ataque) {
        this.nome = nome;
        
        if (vida < 1) {
            this.vida = 1;
        } else {
            this.vida = vida;
        }

        if (ataque < 0) {
            this.ataque = 0;
        } else {
            this.ataque = ataque;
        }
    }

    // Getters
    public String getNome() {
        return nome;
    }

    public int getVida() {
        return vida;
    }

    public int getAtaque() {
        return ataque;
    }

    // Setter com validação (vida não pode ser negativa)
    public void setVida(int vida) {
        if (vida < 0) {
            this.vida = 0;
        } else {
            this.vida = vida;
        }
    }

    // Setter opcional para ataque
    public void setAtaque(int ataque) {
        if (ataque < 0) {
            this.ataque = 0;
        } else {
            this.ataque = ataque;
        }
    }

    // Setter opcional para nome
    public void setNome(String nome) {
        this.nome = nome;
    }

    // Sobrescrita do toString()
    @Override
    public String toString() {
        return "[" + nome + "] Vida: " + vida + " | Ataque: " + ataque;
    }

    // Método principal para teste
    public static void main(String[] args) {
        Personagem p = new Personagem("Guerreiro", 100, 25);
        System.out.println(p); // [Guerreiro] Vida: 100 | Ataque: 25
        
        p.setVida(-10);
        System.out.println("Vida após set negativo: " + p.getVida()); // 0
        
        p.setVida(50);
        System.out.println("Vida após set válido: " + p.getVida()); // 50
    }
}
